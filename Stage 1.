def compute_score(notification: dict) -> float:
    """
    Score = type_weight * 1e9 + unix_timestamp
    Multiplying type_weight by a large constant ensures that a Placement
    notification always outranks any Result, and a Result always outranks
    any Event, regardless of recency.  Within the same type, more recent
    notifications win via their larger unix timestamp.
    """
    type_weight = TYPE_WEIGHT.get(notification.get("Type", ""), 0)
 
    ts_str = notification.get("Timestamp", "1970-01-01 00:00:00")
    try:
        ts = datetime.strptime(ts_str, "%Y-%m-%d %H:%M:%S").timestamp()
    except ValueError:
        ts = 0.0
 
    return type_weight * 1_000_000_000 + ts
 
 
def get_top_n(notifications: list[dict], n: int = TOP_N) -> list[dict]:
    """
    Return the top-N notifications using a fixed-size min-heap.
    This approach scales to a live stream: push each new notification
    and pop when heap size exceeds N → O(log N) per item.
    """
    heap: list[tuple[float, int, dict]] = []   # (score, tie-break, notification)
 
    for idx, notif in enumerate(notifications):
        score = compute_score(notif)
        heapq.heappush(heap, (score, idx, notif))
        if len(heap) > n:
            heapq.heappop(heap)   # evict the lowest-scored item
 
    # Sort descending so index-0 is highest priority
    top = sorted(heap, key=lambda x: x[0], reverse=True)
    return [item[2] for item in top]
 
 
def display_priority_inbox(top_notifications: list[dict]) -> None:
    """Pretty-print the priority inbox."""
    print("\n" + "═" * 65)
    print(f"  🔔  CAMPUS PRIORITY INBOX  — Top {len(top_notifications)} Notifications")
    print("═" * 65)
    print(f"  {'#':<4} {'Type':<12} {'Message':<30} {'Timestamp'}")
    print("─" * 65)
 
    type_icons = {"Placement": "💼", "Result": "📊", "Event": "🎉"}
 
    for rank, notif in enumerate(top_notifications, start=1):
        ntype   = notif.get("Type", "Unknown")
        message = notif.get("Message", "")
        ts      = notif.get("Timestamp", "")
        icon    = type_icons.get(ntype, "🔔")
        print(f"  {rank:<4} {icon} {ntype:<10} {message:<30} {ts}")
 
    print("═" * 65 + "\n")
 
 
